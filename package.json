{
  "name": "bounty-platform",
  "private": true,
  "version": "0.1.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "dotenv": "^16.6.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "hardhat": "^2.24.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-solidity": "^2.3.1",
    "solidity-coverage": "^0.8.17",
    "vue-eslint-parser": "^10.4.0"
  },
  "scripts": {
    "test": "hardhat test",
    "compile": "hardhat compile",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/01_deploy_bounty.js --network localhost",
    "setup:local:erc20": "hardhat run scripts/02_setup_mock.js --network localhost",
    "sync-abi": "node scripts/03_sync_frontend_abi.js",
    "deploy:local:sync": "npm run compile && npm run deploy:local && npm run sync-abi",
    "deploy:sepolia": "hardhat run scripts/01_deploy_bounty.js --network sepolia",
    "verify:sepolia": "hardhat run scripts/verify.js --network sepolia",
    "prepare": "husky install"
  },
  "lint-staged": {
    "contracts/**/*.sol": [
      "prettier --write"
    ],
    "frontend/src/**/*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
